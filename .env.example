# Odoo MCP OAuth Server — environment variables
# Copy this file to .env and fill in your values.

# Public URL of this deployed server (no trailing slash).
# When running locally: http://localhost:3000
# When deployed on Railway: https://your-app.up.railway.app
BASE_URL=http://localhost:3000

# Port to listen on (Railway/Render set this automatically)
PORT=3000
