# Odoo MCP OAuth Server — environment variables
# Copy this file to .env and fill in your values.

# Public URL of this deployed server (no trailing slash).
# When running locally: http://localhost:3000
# When deployed on Railway: https://your-app.up.railway.app
BASE_URL=http://localhost:3000

# Port to listen on (Railway/Render set this automatically)
PORT=3000

# Pre-shared secret for the /register endpoint (RFC 7591).
# When set, POST /register requires: Authorization: Bearer <this value>
# Leave empty only in fully private/trusted deployments.
# Generate with: openssl rand -hex 32
CLIENT_REGISTRATION_SECRET=
